# Groq API (for post generation) - https://console.groq.com/keys
GROQ_API_KEY=

# X / Twitter API v2 OAuth 1.0a (Read+Write) - https://developer.x.com/en/portal/dashboard
X_CONSUMER_KEY=
X_CONSUMER_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=

# Optional: bearer token (only needed if you also want to read your own tweets via API)
# X_BEARER_TOKEN=
